{
  "expo": {
    "name": "SuperCoachNuffies",
    "slug": "SuperCoachNuffies",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "supercoachnuffies",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1228"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ethanfang21.SuperCoachNuffies",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Pick a screenshot of your SuperCoach team so the app can read your players."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1228"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ethanfang21.SuperCoachNuffies"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick a screenshot of your SuperCoach team so the app can read your players."
        }
      ]
    ],
    "developmentClient": {
      "silentLaunch": true
    }
  }
}
